{
  "buildCommand": "cd ai-vue && npm install && npm run build",
  "outputDirectory": "ai-vue/dist",
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "http://159.75.169.224:1235/:path*"
    },
    {
      "source": "/files/:path*",
      "destination": "http://159.75.169.224:1235/files/:path*"
    },
    {
      "source": "/(.*)",
      "destination": "/"
    }
  ]
}